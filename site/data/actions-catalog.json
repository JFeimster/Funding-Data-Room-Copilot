{
  "version": "1.0.0",
  "actions": [
    {
      "id": "build_data_room_package",
      "label": "Build Data Room Package",
      "description": "Assemble the complete folder, checklist, naming, tracker, snapshot, privacy, context, and QA package.",
      "best_for": [
        "complete intake",
        "broker handoff",
        "owner readiness workflow"
      ],
      "typical_inputs": [
        "business profile",
        "funding request",
        "available and missing documents"
      ],
      "key_outputs": [
        "package summary",
        "folder tree",
        "tracker",
        "deal snapshot",
        "readiness QA"
      ],
      "endpoint": "/api/actions/public",
      "privacy_level": "metadata-only",
      "human_review_required": true,
      "tool_url": "../tools/package-builder.html"
    },
    {
      "id": "generate_folder_structure",
      "label": "Generate Folder Structure",
      "description": "Create a business-type-aware folder tree with descriptions and sensitive-folder warnings.",
      "best_for": [
        "new data rooms",
        "clean reorganizations",
        "broker intake"
      ],
      "typical_inputs": [
        "business name",
        "business type",
        "role",
        "funding purpose"
      ],
      "key_outputs": [
        "copy-ready tree",
        "folder descriptions",
        "business-specific additions"
      ],
      "endpoint": "/api/actions/public",
      "privacy_level": "low",
      "human_review_required": true,
      "tool_url": "../tools/folder-structure-builder.html"
    },
    {
      "id": "generate_document_checklist",
      "label": "Generate Document Checklist",
      "description": "Build a categorized checklist that marks received, requested, and not-yet-requested items.",
      "best_for": [
        "document intake",
        "processor review",
        "client follow-up"
      ],
      "typical_inputs": [
        "business type",
        "role",
        "available documents",
        "missing documents"
      ],
      "key_outputs": [
        "sectioned checklist",
        "item status",
        "why it matters"
      ],
      "endpoint": "/api/actions/public",
      "privacy_level": "metadata-only",
      "human_review_required": true,
      "tool_url": "../pages/actions.html#generate-document-checklist"
    },
    {
      "id": "generate_file_naming_rules",
      "label": "Generate File Naming Rules",
      "description": "Turn vague download names into consistent working-copy names without overwriting originals.",
      "best_for": [
        "messy folders",
        "version control",
        "broker operations"
      ],
      "typical_inputs": [
        "business name",
        "current file names"
      ],
      "key_outputs": [
        "naming formula",
        "suggested names",
        "privacy warnings"
