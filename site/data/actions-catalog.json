      "endpoint": "/api/actions/public",
      "privacy_level": "file-name review",
      "human_review_required": true,
      "tool_url": "../pages/actions.html#generate-file-naming-rules"
    },
    {
      "id": "create_missing_document_tracker",
      "label": "Create Missing-Document Tracker",
      "description": "Assign statuses, priorities, owners, and next actions to open document items.",
      "best_for": [
        "follow-up management",
        "broker queues",
        "owner accountability"
      ],
      "typical_inputs": [
        "received items",
        "missing items",
        "status notes"
      ],
      "key_outputs": [
        "operational tracker",
        "priority",
        "owner",
        "next action"
      ],
      "endpoint": "/api/actions/public",
      "privacy_level": "metadata-only",
      "human_review_required": true,
      "tool_url": "../tools/missing-document-tracker.html"
    },
    {
      "id": "generate_deal_snapshot",
      "label": "Generate Deal Snapshot",
      "description": "Create a factual one-page summary of the business, request, documents, gaps, and next step.",
      "best_for": [
        "human review",
        "handoffs",
        "internal deal summaries"
      ],
      "typical_inputs": [
        "business profile",
        "funding request",
        "documents",
        "debt",
        "context"
      ],
      "key_outputs": [
        "business identity",
        "request summary",
        "gaps",
        "QA classification"
      ],
      "endpoint": "/api/actions/public",
      "privacy_level": "redacted facts",
      "human_review_required": true,
      "tool_url": "../pages/actions.html#generate-deal-snapshot"
    },
    {
      "id": "generate_privacy_checklist",
      "label": "Generate Privacy Checklist",
      "description": "Identify credentials, unrestricted sharing, mixed-client files, identity exposure, and redaction needs.",
      "best_for": [
        "pre-share review",
        "clinic workflows",
        "broker operations"
      ],
      "typical_inputs": [
        "privacy constraints",
        "sharing notes",
        "document metadata"
      ],
      "key_outputs": [
        "privacy blockers",
        "redaction checklist",
        "stop-processing flag"
      ],
      "endpoint": "/api/actions/public",
      "privacy_level": "privacy-sensitive",
      "human_review_required": true,
      "tool_url": "../pages/privacy.html"
    },
    {
      "id": "rewrite_context_notes",
      "label": "Rewrite Context Notes",
      "description": "Convert rough cash-flow notes into factual, source-aware explanations with reviewer questions.",
      "best_for": [
        "large transactions",
        "seasonality",
        "payout delays",
        "one-time events"
      ],
      "typical_inputs": [
        "event type",
        "period",
        "amount",
        "explanation",
        "supporting records"
      ],
      "key_outputs": [
        "plain-English note",
        "support suggestions",
        "open facts"
      ],
      "endpoint": "/api/actions/public",
      "privacy_level": "redacted facts",
      "human_review_required": true,
      "tool_url": "../pages/actions.html#rewrite-context-notes"
    },
    {
      "id": "run_readiness_qa_gate",
      "label": "Run Readiness QA Gate",
      "description": "Classify the file as ready, held by a blocker, or provisional pending confirmation.",
      "best_for": [
        "pre-handoff QA",
        "broker review",
        "submission preparation"
      ],
      "typical_inputs": [
        "available documents",
        "missing documents",
        "readiness gaps"
      ],
      "key_outputs": [
        "classification",
        "blockers",
        "fixes",
        "next action"
      ],
      "endpoint": "/api/actions/public",
      "privacy_level": "metadata-only",
      "human_review_required": true,
      "tool_url": "../tools/readiness-qa.html"
    }
  ]
}
